{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parlyx Streamer",
  "version": "0.1.0",
  "identifier": "com.tuckerbradford.parlyx-streamer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Parlyx Streamer",
        "width": 880,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "fullscreen": false,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
